{
  "name": "spotgov-design-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:deploy": "rm -rf public/storybook storybook-static && STORYBOOK_BASE_PATH=/storybook/ npm run build-storybook && cp -r storybook-static public/storybook && test -f public/storybook/index.html && next build",
    "vercel-build": "npm run build:deploy",
    "start": "next start",
    "lint": "next lint",
    "format:write": "prettier --write \"**/*.{ts,tsx,mdx}\" --cache",
    "generate:manifest": "node scripts/generate-manifest.mjs",
    "verify:agent-context": "node scripts/verify-agent-context.mjs",
    "code-connect:preview": "figma connect preview components/ui/*.figma.tsx",
    "code-connect:publish": "figma connect publish",
    "code-connect:publish:dry-run": "figma connect publish --dry-run",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-accordion": "^1.2.1",
