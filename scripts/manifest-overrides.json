      "canonicalExports": ["CheckboxCardShell", "CheckboxCardHeader"]
    },
    "drawer": {
      "purpose": "Side panels",
      "canonicalExports": ["SupportDrawer"],
      "referenceOnlyExports": ["GeneralSettingsDrawer"]
    },
    "file-upload": {
      "purpose": "Upload flows and file status",
      "canonicalExports": ["FileUploadStatusCards"]
    },
    "auth": {
      "purpose": "Auth card patterns",
      "canonicalExports": ["CreateAccountAuthCard", "LoginAuthCard"]
    },
    "command-menu": {
      "purpose": "Command palette patterns",
      "canonicalExports": ["FinanceCommandMenu"]
    },
    "switch": {
      "purpose": "Switch preference demos",
      "canonicalExports": ["NotificationPreferencesSwitch"]
    },
    "text-input": {
      "purpose": "Form input demos",
      "canonicalExports": ["ChangePasswordForm"]
    },
    "token-preview": {
      "purpose": "Design token preview playground — not product UI",
      "referenceOnly": true
    },
    "breadcrumbs": {
      "purpose": "Breadcrumb variants (reference demos)"
    },
    "color-picker": {
      "purpose": "Color picker demos (reference)"
    },
    "datepicker": {
      "purpose": "Date picker demos (reference)"
    },
    "dropdown": {
      "purpose": "Dropdown menus (reference demos)"
    },
    "notification": {
      "purpose": "Notification popover demos (reference)"
    },
    "profile-card": {
      "purpose": "Profile card demos (reference)"
    },
    "radio": {
      "purpose": "Radio card demos (reference)"
    },
    "slider": {
      "purpose": "Slider demos (reference)"
    },
    "tooltip": {
      "purpose": "Tooltip demos (reference)"
    }
  },
  "exportSkipPatterns": [
    "ClassName$",
    "Icon$",
    "FILTER_NAV_ITEMS",
    "FilterNavLabel",
    "getSortingIcon",
    "SortableHeader",
    "createSelectColumn",
    "createActionsColumn",
    "HorizontalDivider",
    "DashedDivider"
